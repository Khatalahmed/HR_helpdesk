GOOGLE_API_KEY=your_google_api_key_here

# Local host defaults (used by non-container scripts on your machine)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=hr_helpdesk
DB_USER=postgres
DB_PASSWORD=postgres
COLLECTION_NAME=hr_helpdesk

# Docker note:
# In docker-compose, API DB_HOST/DB_PORT are overridden to pgvector-db:5432.

GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001

# Optional API protection.
# If APP_API_KEY is set, POST endpoints require header: X-API-Key: <value>
APP_API_KEY=

# Requests allowed per minute per client+endpoint.
RATE_LIMIT_PER_MINUTE=60

# App environment:
# development -> docs enabled
# production  -> /docs and /openapi.json disabled
APP_ENV=development

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
APP_LOG_FILE=api.log
HTTP_LOG_FILE=http.jsonl
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Production server runtime
API_HOST=0.0.0.0
API_PORT=8000
# Keep 1 for Windows local. On Linux server you can increase (e.g., 2 or 4).
API_WORKERS=1
